# Telegram (get from https://my.telegram.org)
TELEGRAM_API_ID=000000
TELEGRAM_API_HASH=your_api_hash_here
TELEPHONE=+490****0000

# Channels
PARSE_CHANNELS=@source_channel
TARGET_CHANNEL=

# Bot token (from @BotFather)
BOT_TOKEN=put_bot_token_here

# Topic
TOPIC_ID=0
CHAT_ID=-1000000000000

# Timing
PARSE_DAYS=1
POLL_INTERVAL=300
POST_DELAY_MIN=10
POST_DELAY_MAX=30

# LLM (OneProvider)
ANTHROPIC_BASE_URL=https://api.oneprovider.dev
ANTHROPIC_API_KEY=put_anthropic_key_here

# Image (cc-vibe)
OPENAI_BASE_URL=https://cc-vibe.com/v1
OPENAI_API_KEY=put_openai_key_here
